# ---------------------------------------------------------------
# Grist source
# ---------------------------------------------------------------
GRIST_API_KEY=your_api_key_here
GRIST_SERVER=https://docs.getgrist.com
GRIST_DOC_ID=your_document_id_here

# Tables à synchroniser (séparées par des virgules)
# Laisser vide pour toutes les prendre
TABLES_TO_SYNC=Clients,Produits,Commandes

# ---------------------------------------------------------------
# MySQL cible
# ---------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_database_name

# ---------------------------------------------------------------
# Comportement
# ---------------------------------------------------------------
DRY_RUN=false
LOG_LEVEL=INFO
